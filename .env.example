HARVEST_ACCESS_TOKEN=your_personal_access_token
HARVEST_ACCOUNT_ID=your_account_id

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Runaway timer: alert threshold in hours (default: 1)
RUNAWAY_THRESHOLD_HOURS=1

# Email (Gmail SMTP with app password)
SMTP_USER=your_email@yourdomain.com
SMTP_APP_PASSWORD=your_app_password
EMAIL_RECIPIENT=recipient@yourdomain.com
CLIENT_EMAIL_RECIPIENT=client@example.com
CLIENT_EMAIL_CC=cc_recipient@example.com

# Healthchecks.io ping URL for monthly export (https://hc-ping.com/<uuid>).
# Leave empty to disable. Configure check on healthchecks.io with cron "0 17 24 * *".
HEALTHCHECK_URL_MONTHLY_EXPORT=
